{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demo-video-generator/schemas/composition.schema.json",
  "title": "Composition",
  "description": "Final composition specification consumed by Remotion's DemoVideo.tsx via renderMedia. composition-director resolves caption absolute timing (start/end/duck_window) from analysis events + caption anchors here. This is the artifact that crosses the Python/Node boundary, so codegen parity (Pydantic + Zod) is non-negotiable.",
  "type": "object",
  "required": ["schema_version", "fps", "duration_seconds", "resolution", "footage", "audio", "captions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "fps": {"type": "integer", "minimum": 1},
    "duration_seconds": {"type": "number", "minimum": 0},
    "resolution": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      }
    },
    "footage": {
      "type": "object",
      "required": ["src"],
      "additionalProperties": false,
      "properties": {
        "src": {"type": "string", "description": "Path to footage.mp4 relative to the run dir."},
        "trim_before": {"type": "number", "default": 0, "description": "Remotion v4 prop name (was trimLeft)."},
        "trim_after": {"type": "number"}
      }
    },
    "audio": {
      "type": "object",
      "required": ["music", "sfx", "mix"],
      "additionalProperties": false,
      "properties": {
        "music": {
          "type": "object",
          "required": ["src"],
          "additionalProperties": false,
          "properties": {
            "src": {"type": "string"},
            "gain_db": {"type": "number", "default": 0}
          }
        },
        "sfx": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["src", "t"],
            "additionalProperties": false,
            "properties": {
              "src": {"type": "string"},
              "t": {"type": "number", "minimum": 0, "description": "Absolute time in seconds."},
              "gain_db": {"type": "number", "default": 0},
              "anchor_event_id": {"type": ["string", "null"]}
            }
          }
        },
        "mix": {
          "type": "object",
          "description": "Targets enforced by qa-reviewer. YouTube-aligned per v2.1.",
          "additionalProperties": false,
          "properties": {
            "integrated_lufs": {"type": "number", "default": -14},
            "true_peak_dbtp": {"type": "number", "default": -1},
            "duck_to_lufs": {"type": "number", "default": -22}
          }
        }
      }
    },
    "captions": {
      "type": "array",
      "description": "Caption layout WITH absolute timing resolved by composition-director (anchor_event_id + intent_duration → start/end/duck_window).",
      "items": {"$ref": "#/$defs/RenderedCaption"}
    }
  },
  "$defs": {
    "RenderedCaption": {
      "type": "object",
      "required": ["id", "text", "mood", "start", "end"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"},
        "mood": {
          "type": "string",
          "enum": ["announce", "explain", "punchline", "aside", "callout", "tagline"]
        },
        "start": {"type": "number", "minimum": 0},
        "end": {"type": "number", "minimum": 0},
        "duck_window": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "start": {"type": "number"},
            "end": {"type": "number"}
          }
        }
      }
    }
  }
}
